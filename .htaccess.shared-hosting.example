# Esempio da usare solo se il provider non consente di impostare `public/`
# come document root del dominio.
#
# Modalita consigliata: usare direttamente `/public` come webroot.
# Questo file e un fallback per installazioni shared hosting piu limitate.

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>
