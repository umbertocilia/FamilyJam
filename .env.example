CI_ENVIRONMENT = production

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
app.baseURL = 'https://familyjam.example.com/'
app.forceGlobalSecureRequests = true
app.CSPEnabled = false

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = familyjam
database.default.username = familyjam_user
database.default.password = change-me
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci
database.default.DBDebug = false

# ------------------------------------------------------------------------------
# Encryption
# Generate a real key with:
# php spark key:generate
# ------------------------------------------------------------------------------
encryption.key = base64:CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# ------------------------------------------------------------------------------
# Session / Cookies
# Use an absolute path valid on your server.
# Example:
# /home/account/familyjam/writable/session
# ------------------------------------------------------------------------------
session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.savePath = /path/to/project/writable/session

cookie.secure = true
cookie.httponly = true
cookie.samesite = Lax

# ------------------------------------------------------------------------------
# Logging
# 4 = errors + warnings
# 9 = verbose debug (only for temporary troubleshooting)
# ------------------------------------------------------------------------------
logger.threshold = 4

# ------------------------------------------------------------------------------
# Email / SMTP
# ------------------------------------------------------------------------------
email.fromEmail = 'no-reply@example.com'
email.fromName = 'FamilyJam'
email.protocol = 'smtp'
email.SMTPHost = 'smtp.example.com'
email.SMTPUser = 'no-reply@example.com'
email.SMTPPass = 'change-me'
email.SMTPPort = 587
email.SMTPCrypto = 'tls'
email.SMTPTimeout = 15
email.mailType = 'html'

# ------------------------------------------------------------------------------
# Optional test database
# ------------------------------------------------------------------------------
# database.tests.hostname = 127.0.0.1
# database.tests.database = familyjam_test
# database.tests.username = familyjam_test_user
# database.tests.password = change-me
# database.tests.DBDriver = MySQLi
# database.tests.DBPrefix =
# database.tests.port = 3306
# database.tests.charset = utf8mb4
# database.tests.DBCollat = utf8mb4_unicode_ci
# database.tests.DBDebug = true
